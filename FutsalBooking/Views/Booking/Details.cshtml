@model FutsalBooking.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white d-flex justify-content-between">
                    <h5 class="mb-0">Booking #@Model.Id</h5>
                    @{
                        string badgeClass;

                        if (Model.Status == BookingStatus.Confirmed)
                        {
                            badgeClass = "bg-light text-success";
                        }
                        else if (Model.Status == BookingStatus.Pending)
                        {
                            badgeClass = "bg-warning text-dark";
                        }
                        else if (Model.Status == BookingStatus.Cancelled)
                        {
                            badgeClass = "bg-danger text-white";
                        }
                        else
                        {
                            badgeClass = "bg-secondary text-white";
                        }
                    }
                    <span class="badge @badgeClass">@Model.Status</span>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Date</small>
                        <div class="fw-semibold">@Model.BookingDate.ToString("dddd, dd MMM yyyy")</div>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Time</small>
                        <div class="fw-semibold">@Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")</div>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Total Amount</small>
                        <div class="fw-bold text-success fs-4">Rs. @Model.TotalAmount.ToString("N0")</div>
                    </div>
                    <div class="mb-3 pb-3 border-bottom">
                        <small class="text-muted">Payment</small>
                        <div>
                            <span class="badge @(Model.PaymentStatus == PaymentStatus.Paid ? "bg-success" : "bg-danger")">
                                @Model.PaymentStatus
                            </span>
                        </div>
                    </div>
                    <div class="mb-4">
                        <small class="text-muted">Booked On</small>
                        <div>@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Back</a>
                        @if (Model.Status == BookingStatus.Pending || Model.Status == BookingStatus.Confirmed)
                        {
                            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="flex-fill" onsubmit="return confirm('are you sure?')">
                                <button type="submit" class="btn btn-danger w-100">Cancel Booking</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>