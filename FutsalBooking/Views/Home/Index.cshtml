@model FutsalBooking.Models.Court
@{
    ViewData["Title"] = "Home";
    var todayBookings = ViewBag.TodayBookings as List<FutsalBooking.Models.Booking> ?? new();
    var currentUserId = ViewBag.CurrentUserId as string;
}

<!-- hero section -->
<div class="hero-section">
    <div class="container">
        <h1 class="display-4 fw-bold mb-2">SGlory Futsal</h1>
        <p class="lead mb-4">Srijananagar, Bhaktapur &nbsp;|&nbsp; Open 6AM to 10PM daily</p>
        @if (!User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-4 me-2">Login to Book</a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg px-4">Register Free</a>
        }
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            @if (Model != null)
            {
                <!-- court info card -->
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <i class="fas fa-futbol me-2"></i>@Model.Name
                    </div>
                    <div class="card-body p-4">
                        <div class="row text-center">
                            <div class="col-4">
                                <h4 class="text-primary fw-bold">Rs. @Model.PricePerHour.ToString("N0")</h4>
                                <small class="text-muted">Per Hour</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-primary fw-bold">6 AM</h4>
                                <small class="text-muted">Opens</small>
                            </div>
                            <div class="col-4">
                                <h4 class="text-primary fw-bold">10 PM</h4>
                                <small class="text-muted">Closes</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- today's time slots -->
                <div class="card">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <span><i class="fas fa-calendar-day me-2"></i>Today's Available Slots</span>
                        <span class="small">@DateTime.Today.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="card-body p-3">

                        @if (!Model.IsActive)
                        {
                            <div class="alert alert-warning mb-0">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                Court is temporarily closed. No bookings available.
                            </div>
                        }
                        else
                        {
                            //generate slots from 6AM to 10PM 
                            @for (int hour = 6; hour < 22; hour++)
                            {
                                var slotStart = new TimeSpan(hour, 0, 0);
                                var slotEnd = new TimeSpan(hour + 1, 0, 0);
                                var slotStartStr = hour.ToString("D2") + ":00";
                                var slotEndStr = (hour + 1).ToString("D2") + ":00";

                                // check if this slot is booked
                                var existingBooking = todayBookings.FirstOrDefault(b =>
                                b.StartTime <= slotStart && b.EndTime > slotStart);

                                bool isMyBooking = existingBooking != null &&
                                existingBooking.UserId == currentUserId;
                                bool isBooked = existingBooking != null;

                                // skip past slots
                                bool isPast = slotEnd <= DateTime.Now.TimeOfDay;

                                <div class="time-slot @(isMyBooking ? "my-slot" : isBooked ? "booked-slot" : isPast ? "past-slot" : "")">
                                    <span class="fw-semibold @(isMyBooking ? "text-success" : isBooked ? "text-danger" : isPast ? "text-muted" : "")">
                                        @slotStartStr - @slotEndStr
                                    </span>
                                    <div>
                                        @if (isMyBooking)
                                        {
                                            <a asp-controller="Booking" asp-action="Details"
                                               asp-route-id="@existingBooking!.Id"
                                               class="btn btn-sm btn-outline-success me-1">Details</a>
                                            <form asp-controller="Booking" asp-action="Cancel"
                                                  asp-route-id="@existingBooking!.Id"
                                                  method="post" class="d-inline"
                                                  onsubmit="return confirm('cancel this booking?')">
                                                <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                                            </form>
                                        }
                                        else if (isBooked)
                                        {
                                            <span class="btn btn-sm btn-danger disabled">Booked</span>
                                        }
                                        else if (isPast)
                                        {
                                            <span class="btn btn-sm btn-secondary disabled">Past</span>
                                        }
                                        else if (User.Identity!.IsAuthenticated)
                                        {
                                            <a asp-controller="Booking" asp-action="Create"
                                               class="btn btn-sm btn-primary">Book Now</a>
                                        }
                                        else
                                        {
                                            <a asp-controller="Account" asp-action="Login"
                                               class="btn btn-sm btn-outline-primary">Login to Book</a>
                                        }
                                    </div>
                                </div>
                            }
                        }

                    </div>
                </div>
            }

        </div>
    </div>
</div>