@model FutsalBooking.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-receipt me-2"></i>Booking #@Model.Id</h5>
                    @{
                        var statusClass = Model.Status switch
                        {
                            FutsalBooking.Models.BookingStatus.Confirmed => "bg-light text-success",
                            FutsalBooking.Models.BookingStatus.Pending => "bg-warning text-dark",
                            FutsalBooking.Models.BookingStatus.Cancelled => "bg-danger text-white",
                            _ => "bg-secondary text-white"
                        };
                    }
                    <span class="badge @statusClass fs-6">@Model.Status</span>
                </div>
                <div class="card-body p-4">

                    <div class="detail-row mb-3 pb-3 border-bottom">
                        <label class="text-muted small">Court</label>
                        <div class="fw-bold fs-5">@Model.Court?.Name</div>
                        <span class="badge bg-primary">@Model.Court?.CourtType</span>
                    </div>

                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-6">
                            <label class="text-muted small">Date</label>
                            <div class="fw-semibold">@Model.BookingDate.ToString("dddd, dd MMM yyyy")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small">Time</label>
                            <div class="fw-semibold">
                                @Model.StartTime.ToString(@"hh\:mm") – @Model.EndTime.ToString(@"hh\:mm")
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3 pb-3 border-bottom">
                        <div class="col-6">
                            <label class="text-muted small">Total Amount</label>
                            <div class="fw-bold text-success fs-4">Rs. @Model.TotalAmount.ToString("N0")</div>
                        </div>
                        <div class="col-6">
                            <label class="text-muted small">Payment Status</label>
                            <div>
                                @if (Model.PaymentStatus == FutsalBooking.Models.PaymentStatus.Paid)
                                {
                                    <span class="badge bg-success fs-6">
                                        <i class="fas fa-check-circle me-1"></i>Paid
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">Unpaid</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="mb-3 pb-3 border-bottom">
                        <label class="text-muted small">Booked On</label>
                        <div>@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="mb-3 pb-3 border-bottom">
                            <label class="text-muted small">Notes</label>
                            <div>@Model.Notes</div>
                        </div>
                    }

                    @* show khalti pay button only if not yet paid and not cancelled *@
                    @if (Model.PaymentStatus != FutsalBooking.Models.PaymentStatus.Paid &&
                         Model.Status != FutsalBooking.Models.BookingStatus.Cancelled)
                    {
                        <div class="khalti-section p-3 bg-light rounded mb-3">
                            <p class="mb-2 fw-semibold">Pay Online with Khalti</p>
                            <p class="text-muted small mb-3">
                                Pay Rs. @Model.TotalAmount.ToString("N0") securely using Khalti digital wallet.
                            </p>
                            <form asp-controller="Payment" asp-action="InitiatePayment" method="post">
                                <input type="hidden" name="bookingId" value="@Model.Id" />
                                <button type="submit" class="btn btn-khalti w-100">
                                    <img src="https://khalti.com/static/images/logo.png"
                                         alt="Khalti" height="20" class="me-2"
                                         onerror="this.style.display='none'" />
                                    Pay with Khalti — Rs. @Model.TotalAmount.ToString("N0")
                                </button>
                            </form>
                            <p class="text-muted small mt-2 mb-0">
                                <i class="fas fa-shield-alt me-1"></i>
                                Secure payment · You will be redirected to Khalti
                            </p>
                        </div>
                    }

                    @if (Model.PaymentStatus == FutsalBooking.Models.PaymentStatus.Paid)
                    {
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle me-2"></i>
                            Payment completed. Your booking is confirmed!
                        </div>
                    }

                    <div class="d-flex gap-2 mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="fas fa-arrow-left me-2"></i>Back
                        </a>
                        @if (Model.Status == FutsalBooking.Models.BookingStatus.Pending ||
                             Model.Status == FutsalBooking.Models.BookingStatus.Confirmed)
                        {
                            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="flex-fill"
                                  onsubmit="return confirm('Are you sure you want to cancel?')">
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="fas fa-times me-2"></i>Cancel Booking
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
