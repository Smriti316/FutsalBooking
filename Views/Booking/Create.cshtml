@model FutsalBooking.Models.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Book Court";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-calendar-plus me-2"></i>Book a Court</h5>
                </div>
                <div class="card-body p-4">

                    @if (Model.Court != null)
                    {
                        <div class="court-info-box mb-4 p-3 bg-light rounded">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h5 class="mb-1">@Model.Court.Name</h5>
                                    <span class="badge @(Model.Court.CourtType == "Indoor" ? "bg-primary" : "bg-success")">@Model.Court.CourtType</span>
                                </div>
                                <div class="text-end">
                                    <div class="fs-4 fw-bold text-success">Rs. @Model.Court.PricePerHour.ToString("N0")</div>
                                    <small class="text-muted">per hour</small>
                                </div>
                            </div>
                        </div>
                    }

                    <form asp-action="Create" method="post" id="bookingForm">
                        <div asp-validation-summary="All" class="alert alert-danger"></div>
                        <input asp-for="CourtId" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="BookingDate" class="form-label fw-semibold"></label>
                            <input asp-for="BookingDate" type="date" class="form-control"
                                   min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                                   max="@DateTime.Today.AddDays(30).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="BookingDate" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-6 mb-3">
                                <label asp-for="StartTime" class="form-label fw-semibold">Start Time</label>
                                <select asp-for="StartTime" class="form-select" id="startTime">
                                    @for (int h = 6; h < 22; h++)
                                    {
                                        <option value="@h.ToString("D2"):00">@h.ToString("D2"):00 @(h < 12 ? "AM" : "PM")</option>
                                    }
                                </select>
                                <span asp-validation-for="StartTime" class="text-danger small"></span>
                            </div>
                            <div class="col-6 mb-3">
                                <label asp-for="EndTime" class="form-label fw-semibold">End Time</label>
                                <select asp-for="EndTime" class="form-select" id="endTime">
                                    @for (int h = 7; h <= 22; h++)
                                    {
                                        <option value="@h.ToString("D2"):00">@h.ToString("D2"):00 @(h < 12 ? "AM" : "PM")</option>
                                    }
                                </select>
                                <span asp-validation-for="EndTime" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Total Estimate -->
                        <div class="total-box p-3 bg-success bg-opacity-10 rounded mb-3" id="totalBox">
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold">Estimated Total:</span>
                                <span class="fw-bold text-success fs-5" id="totalAmount">Rs. 0</span>
                            </div>
                            <small class="text-muted" id="durationText"></small>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-semibold">Special Notes (Optional)</label>
                            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Any special requirements..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">
                            <i class="fas fa-check-circle me-2"></i>Confirm Booking
                        </button>
                        <a asp-controller="Home" asp-action="Courts" class="btn btn-outline-secondary w-100 mt-2">
                            Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const pricePerHour = @(Model.Court?.PricePerHour ?? 0);

    function updateTotal() {
        const start = parseInt(document.getElementById('startTime').value.split(':')[0]);
        const end = parseInt(document.getElementById('endTime').value.split(':')[0]);
        const hours = end - start;

        if (hours > 0) {
            const total = hours * pricePerHour;
            document.getElementById('totalAmount').textContent = 'Rs. ' + total.toLocaleString();
            document.getElementById('durationText').textContent = hours + ' hour(s) × Rs. ' + pricePerHour.toLocaleString();
        } else {
            document.getElementById('totalAmount').textContent = 'Rs. 0';
            document.getElementById('durationText').textContent = 'Select valid time range';
        }
    }

    document.getElementById('startTime').addEventListener('change', updateTotal);
    document.getElementById('endTime').addEventListener('change', updateTotal);
    updateTotal();
</script>
}
