@model List<FutsalBooking.Models.Court>
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- hero banner -->
<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container hero-content text-center text-white">
        <h1 class="hero-title">PlayZone Futsal</h1>
        <p class="hero-subtitle">Book your court online · Baneshwor, Kathmandu · Open 6AM to 10PM daily</p>
        <div class="hero-actions">
            <a asp-controller="Home" asp-action="Courts" class="btn btn-success btn-lg px-5 me-3">
                <i class="fas fa-calendar-check me-2"></i>Book Now
            </a>
            @if (!User.Identity!.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg px-4">
                    Create Free Account
                </a>
            }
        </div>
    </div>
</section>

<!-- quick info bar -->
<section class="stats-bar py-4">
    <div class="container">
        <div class="row text-center">
            <div class="col-3">
                <div class="stat-item">
                    <h3 class="text-success">4</h3>
                    <p>Courts Available</p>
                </div>
            </div>
            <div class="col-3">
                <div class="stat-item">
                    <h3 class="text-success">6 AM</h3>
                    <p>Opens Daily</p>
                </div>
            </div>
            <div class="col-3">
                <div class="stat-item">
                    <h3 class="text-success">10 PM</h3>
                    <p>Closes Daily</p>
                </div>
            </div>
            <div class="col-3">
                <div class="stat-item">
                    <h3 class="text-success">Rs.800+</h3>
                    <p>Starting Price</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- courts section -->
<section class="py-5">
    <div class="container">
        <div class="section-header text-center mb-5">
            <h2>Our Courts</h2>
            <p class="text-muted">We have @Model.Count courts available for booking</p>
        </div>

        <div class="row g-4">
            @foreach (var court in Model)
            {
                <div class="col-md-6 col-lg-3">
                    <div class="court-card card h-100">
                        <div class="court-card-img">
                            <span class="court-type-badge badge @(court.CourtType == "Indoor" ? "bg-primary" : "bg-success")">
                                @court.CourtType
                            </span>
                            <div class="court-icon">
                                <i class="fas fa-futbol fa-3x text-success opacity-50"></i>
                            </div>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@court.Name</h5>
                            <p class="card-text text-muted small">@court.Description</p>
                            <div class="price-tag mt-2">
                                <span class="fs-5 fw-bold text-success">Rs. @court.PricePerHour.ToString("N0")</span>
                                <span class="text-muted small"> /hr</span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top">
                            @if (User.Identity.IsAuthenticated)
                            {
                                <a asp-controller="Booking" asp-action="Create" asp-route-courtId="@court.Id"
                                   class="btn btn-success w-100">
                                    <i class="fas fa-calendar-plus me-2"></i>Book This Court
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-success w-100">
                                    Login to Book
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- how to book section -->
<section class="how-section py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-5">How to Book</h2>
        <div class="row text-center g-4">
            <div class="col-md-4">
                <div class="step-card p-4">
                    <div class="step-number">1</div>
                    <i class="fas fa-user-plus fa-2x text-success mb-3 mt-3"></i>
                    <h5>Create Account</h5>
                    <p class="text-muted small">Register with your email and phone number. Its free.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card p-4">
                    <div class="step-number">2</div>
                    <i class="fas fa-calendar-alt fa-2x text-success mb-3 mt-3"></i>
                    <h5>Pick Court & Time</h5>
                    <p class="text-muted small">Select your preferred court, date and time slot.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card p-4">
                    <div class="step-number">3</div>
                    <i class="fas fa-running fa-2x text-success mb-3 mt-3"></i>
                    <h5>Come & Play!</h5>
                    <p class="text-muted small">Show up at the court and pay at the reception.</p>
                </div>
            </div>
        </div>
    </div>
</section>
