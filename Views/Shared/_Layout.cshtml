<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PlayZone Futsal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark sticky-top">
    <div class="container">
        <a class="navbar-brand" href="/">
            <i class="fas fa-futbol me-2"></i>PlayZone Futsal
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Courts">Courts</a>
                </li>
                @if (User.Identity!.IsAuthenticated)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Booking" asp-action="Index">My Bookings</a>
                    </li>
                }
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Admin" asp-action="Dashboard">
                            <i class="fas fa-cog me-1"></i>Admin Panel
                        </a>
                    </li>
                }
            </ul>
            <ul class="navbar-nav">
                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i>@User.Identity.Name
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-2"></i>Logout
                                </a>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-success btn-sm ms-2 px-3" asp-controller="Account" asp-action="Register">
                            Register
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@* show success message if any *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
        <div class="container">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<main>
    @RenderBody()
</main>

<footer class="footer mt-5">
    <div class="container">
        <div class="row py-4">
            <div class="col-md-4 mb-3">
                <h5><i class="fas fa-futbol me-2"></i>PlayZone Futsal</h5>
                <p class="text-muted small">
                    Online booking system for PlayZone Futsal, Kathmandu.
                    Book your court in minutes.
                </p>
            </div>
            <div class="col-md-4 mb-3">
                <h6>Links</h6>
                <ul class="list-unstyled small">
                    <li><a href="/" class="text-muted">Home</a></li>
                    <li><a asp-controller="Home" asp-action="Courts" class="text-muted">View Courts</a></li>
                    <li><a asp-controller="Account" asp-action="Register" class="text-muted">Create Account</a></li>
                </ul>
            </div>
            <div class="col-md-4 mb-3">
                <h6>Contact Us</h6>
                <p class="text-muted small"><i class="fas fa-phone me-2"></i>+977-9812345678</p>
                <p class="text-muted small"><i class="fas fa-map-marker-alt me-2"></i>Baneshwor, Kathmandu</p>
                <p class="text-muted small"><i class="fas fa-envelope me-2"></i>playzonefutsal@gmail.com</p>
                <p class="text-muted small"><i class="fas fa-clock me-2"></i>Open: 6:00 AM - 10:00 PM</p>
            </div>
        </div>
        <hr />
        <p class="text-center text-muted small mb-0">
            &copy; 2024 PlayZone Futsal, Kathmandu. All rights reserved.
        </p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
