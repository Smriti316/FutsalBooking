@model List<FutsalBooking.Models.Booking>
@{
    ViewData["Title"] = "All Bookings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-list me-2 text-success"></i>All Bookings</h2>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Dashboard
        </a>
    </div>

    <!-- Filter Buttons -->
    <div class="mb-3">
        <a asp-action="Bookings" class="btn btn-sm @(ViewBag.CurrentStatus == null ? "btn-dark" : "btn-outline-dark") me-1">All</a>
        <a asp-action="Bookings" asp-route-status="Pending" class="btn btn-sm btn-outline-warning me-1">Pending</a>
        <a asp-action="Bookings" asp-route-status="Confirmed" class="btn btn-sm btn-outline-success me-1">Confirmed</a>
        <a asp-action="Bookings" asp-route-status="Cancelled" class="btn btn-sm btn-outline-danger me-1">Cancelled</a>
        <a asp-action="Bookings" asp-route-status="Completed" class="btn btn-sm btn-outline-secondary">Completed</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Customer</th>
                            <th>Court</th>
                            <th>Date & Time</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Payment</th>
                            <th>Update</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model)
                        {
                            <tr>
                                <td>@b.Id</td>
                                <td>
                                    <strong>@b.User?.FullName</strong><br/>
                                    <small class="text-muted">@b.User?.PhoneNumber</small>
                                </td>
                                <td>@b.Court?.Name</td>
                                <td>
                                    @b.BookingDate.ToString("dd MMM yyyy")<br/>
                                    <small>@b.StartTime.ToString(@"hh\:mm") – @b.EndTime.ToString(@"hh\:mm")</small>
                                </td>
                                <td class="text-success fw-bold">Rs. @b.TotalAmount.ToString("N0")</td>
                                <td>
                                    @{
                                        var sc = b.Status switch {
                                            FutsalBooking.Models.BookingStatus.Confirmed => "bg-success",
                                            FutsalBooking.Models.BookingStatus.Pending => "bg-warning text-dark",
                                            FutsalBooking.Models.BookingStatus.Cancelled => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @sc">@b.Status</span>
                                </td>
                                <td>
                                    <form asp-action="UpdatePaymentStatus" method="post">
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                                            @foreach (var ps in Enum.GetValues<FutsalBooking.Models.PaymentStatus>())
                                            {
                                                <option value="@ps" @(b.PaymentStatus == ps ? "selected" : "")>@ps</option>
                                            }
                                        </select>
                                    </form>
                                </td>
                                <td>
                                    <form asp-action="UpdateBookingStatus" method="post">
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                                            @foreach (var s in Enum.GetValues<FutsalBooking.Models.BookingStatus>())
                                            {
                                                <option value="@s" @(b.Status == s ? "selected" : "")>@s</option>
                                            }
                                        </select>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
